# Variáveis públicas do Next.js (NEXT_PUBLIC_*) — expostas no client.
# Demais vão pro processo Node apenas.

# Supabase (anon key — segura no client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# API interna (Next reescreve /api/* pra esse endereço)
INTERNAL_API_URL=http://127.0.0.1:8012

# Analytics (Google Analytics 4 Measurement ID)
# Em dev local, deixe vazio pra não poluir métricas de produção.
NEXT_PUBLIC_GA_ID=
