[Unit]
Description=MudAcao Escala Freemium Web (Next.js)
After=network.target escala-freemium-api.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/escala-freemium/apps/web
EnvironmentFile=/opt/escala-freemium/.env
Environment="NODE_ENV=production"
Environment="PATH=/home/deploy/.local/share/pnpm:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/usr/bin/node node_modules/next/dist/bin/next start -p 8011
Restart=on-failure
RestartSec=3

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/escala-freemium

[Install]
WantedBy=multi-user.target
