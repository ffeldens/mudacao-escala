# =============================================================================
# MudAção Escala Freemium — Variáveis de ambiente
# =============================================================================
# Copie pra .env (não commitado) e preencha os valores reais.
#
# ⚠️ IMPORTANTE: pydantic-settings NÃO suporta comentários inline (após o valor).
# Comentários só em linhas próprias começando com #.

# -----------------------------------------------------------------------------
# Supabase (mesmo projeto do T&F, schema "freemium")
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...

# Service role: só backend, NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Postgres connection string (Transaction Pooler + psycopg)
DATABASE_URL=postgresql+psycopg://postgres.PROJREF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Resend (email transacional + marketing)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=simulador@mudacao.com.br
RESEND_REPLY_TO=felipe@mudacao.com.br

# Email do admin recebe notificação a cada lead capturado.
# Deixe vazio pra desativar.
ADMIN_NOTIFY_EMAIL=felipe@mudacao.com.br

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# APP_ENV: development | production
APP_ENV=development

# Porta da web (Next.js)
APP_PORT_WEB=8011

# Porta da API (FastAPI)
APP_PORT_API=8012

# Em prod, use: https://simulaescala.mudacao.com.br
APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe (Sprint 2 — deixar vazio no MVP)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Analytics (opcional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
