# =============================================================================
# MudAção Escala Freemium — Variáveis de ambiente
# =============================================================================
# Copie pra .env (não commitado) e preencha os valores reais.

# -----------------------------------------------------------------------------
# Supabase (mesmo projeto do T&F, schema "freemium")
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # só backend, NUNCA expor no frontend

# Postgres connection string (Transaction Pooler + psycopg)
DATABASE_URL=postgresql+psycopg://postgres.PROJREF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Resend (email transacional + marketing)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=simulador@mudacao.com.br
RESEND_REPLY_TO=felipe@feldens.com

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development             # development | production
APP_PORT_WEB=8011               # Next.js
APP_PORT_API=8012               # FastAPI
APP_BASE_URL=http://localhost:3000  # em prod: https://simulaescala.mudacao.com.br

# -----------------------------------------------------------------------------
# Stripe (Sprint 2 — deixar vazio no MVP)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Analytics (opcional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
