# =============================================================================
# MudAção Escala Freemium — Variáveis de ambiente
# =============================================================================
# Copie pra .env (não commitado) e preencha os valores reais.
#
# ⚠️ IMPORTANTE: pydantic-settings NÃO suporta comentários inline (após o valor).
# Comentários só em linhas próprias começando com #.

# -----------------------------------------------------------------------------
# Supabase (mesmo projeto do T&F, schema "freemium")
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...

# Service role: só backend, NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# JWT secret pra backend validar tokens (Supabase dashboard → Settings → API)
SUPABASE_JWT_SECRET=

# Mesmas vars expostas pro frontend Next.js (necessário pro Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Postgres connection string (Transaction Pooler + psycopg)
DATABASE_URL=postgresql+psycopg://postgres.PROJREF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Resend (email transacional + marketing)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=simulador@mudacao.com.br
RESEND_REPLY_TO=felipe@feldens.com

# Email do admin recebe notificação a cada lead capturado.
# Deixe vazio pra desativar.
ADMIN_NOTIFY_EMAIL=felipe@feldens.com

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# APP_ENV: development | production
APP_ENV=development

# Porta da web (Next.js)
APP_PORT_WEB=8011

# Porta da API (FastAPI)
APP_PORT_API=8012

# Em prod, use: https://simulaescala.mudacao.com.br
APP_BASE_URL=http://localhost:3000

# Mesmo valor exposto pro Next.js (precisa do prefixo NEXT_PUBLIC_ pra bakear no build)
# Usado no auth/callback pra construir redirects corretos atrás do proxy Caddy.
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe (Sprint 2 — checkout + webhook)
# -----------------------------------------------------------------------------
# Modo teste: sk_test_... / pk_test_...
# Modo produção: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Price ID do plano Starter (criado no Dashboard Stripe → Products)
STRIPE_PRICE_ID_STARTER=

# Webhook secret (gerado quando criar o endpoint em Stripe → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=

# Dias de trial gratuito (default: 14)
STRIPE_TRIAL_DAYS=14

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID (formato: G-XXXXXXXXXX)
# Quando setado, GA4 é injetado no <head> automaticamente.
# Em dev, deixe vazio pra não poluir métricas de produção.
NEXT_PUBLIC_GA_ID=G-WSZ49TXY57
